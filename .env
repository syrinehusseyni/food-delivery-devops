# ============================================
# Food Delivery - Variables d'environnement
# ============================================

# PostgreSQL Database
POSTGRES_DB=fooddelivery
POSTGRES_USER=postgres
POSTGRES_PASSWORD=syrine1254xxy
# Note: PostgreSQL runs on port 5432 internally, mapped to 5433 externally

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@fooddelivery.com
PGADMIN_DEFAULT_PASSWORD=admin
# Note: pgAdmin runs on port 80 internally, mapped to 5051 externally

# Eureka Server
EUREKA_PORT=8761

# API Gateway
GATEWAY_PORT=9000

# Microservices Ports
USER_SERVICE_PORT=8081
RESTAURANT_SERVICE_PORT=8082
DELIVERY_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8085
ADMIN_SERVICE_PORT=8089

# JWT Configuration (shared across services)
JWT_SECRET=b8f1339f-bb76-4d62-abd9-4adde208ee3f
JWT_EXPIRATION=3600000

# Frontend (Vite dev server port)
FRONTEND_PORT=5173

# Network
NETWORK_NAME=fooddelivery-network
